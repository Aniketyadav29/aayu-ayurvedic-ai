# =============================================================
# AAYU Ayurvedic AI — Environment Variables
# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to Git.
# =============================================================

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override default model (default: models/gemini-2.0-flash)
# GEMINI_MODEL=models/gemini-2.0-flash

# --- Twilio (WhatsApp) ---
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_NUMBER=whatsapp:+14155238886

# --- Security ---
# Set to "true" in production to enforce Twilio webhook signature validation
ENFORCE_TWILIO_SIGNATURE=false

# Secret token to authenticate the /send-reminders cron endpoint
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REMINDER_CRON_TOKEN=your_cron_secret_token_here

# --- Feature Flags ---
AAYU_RAG_PRIMARY_ENABLED=true
AAYU_AI_BRAIN_ENABLED=true

# --- Deployment ---
# Set to your public URL in production (e.g. https://your-app.onrender.com)
# Required for menu image URLs to work correctly via Twilio
PUBLIC_BASE_URL=
